local autoCheckpointToggle = false
local autoRebirthToggle = false

CreateButton("Auto Checkpoint", MainTab, function(btn)
    autoCheckpointToggle = not autoCheckpointToggle
    if autoCheckpointToggle then
        btn.BackgroundTransparency = 0.2
        CustomNotify("Auto Checkpoint", "Auto Checkpoint Enabled")
        task.spawn(function()
            local checkpointFolder = workspace:WaitForChild("Checkpoints")
            local index = 1

            while autoCheckpointToggle do
                local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                local hrp = character:FindFirstChild("HumanoidRootPart")
                
                if hrp then
                    local nextCheckpoint = checkpointFolder:FindFirstChild(tostring(index))
                    
                    if nextCheckpoint and nextCheckpoint:IsA("BasePart") then
                        hrp.CFrame = CFrame.new(nextCheckpoint.Position + Vector3.new(0, 3, 0))
                        
                        local touchInterest = nextCheckpoint:FindFirstChildWhichIsA("TouchTransmitter") or nextCheckpoint:FindFirstChild("TouchInterest")
                        if touchInterest then
                            firetouchinterest(hrp, nextCheckpoint, 0)
                            task.wait()
                            firetouchinterest(hrp, nextCheckpoint, 1)
                        end
                        
                        task.wait(0.5)
                        index = index + 1
                    else
                        CustomNotify("Auto Checkpoint", "Finished! No more checkpoints left.")
                        autoCheckpointToggle = false
                        btn.BackgroundTransparency = 0.5
                        break
                    end
                else
                    task.wait(0.5)
                end
            end
        end)
    else
        btn.BackgroundTransparency = 0.5
        CustomNotify("Auto Checkpoint", "Auto Checkpoint Disabled")
    end
end)

